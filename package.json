{
  "name": "annotations-design-patterns",
  "version": "1.1.0",
  "description": "Design patterns as standard TC39 TypeScript decorators: GoF patterns, resilience toolkit (retry, circuit breaker, fallback) and method utilities. Zero dependencies, tree-shakeable.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stealman364/annotationsDesignPatterns.git"
  },
  "homepage": "https://github.com/stealman364/annotationsDesignPatterns#readme",
  "bugs": {
    "url": "https://github.com/stealman364/annotationsDesignPatterns/issues"
  },
  "keywords": [
    "decorators",
    "typescript",
    "design-patterns",
    "tc39",
    "gof",
    "singleton",
    "observer",
    "strategy",
    "factory",
    "state-machine",
    "memoize",
    "debounce",
    "throttle",
    "retry",
    "circuit-breaker",
    "fallback",
    "resilience"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./*": {
      "import": {
        "types": "./dist/patterns/*.d.ts",
        "default": "./dist/patterns/*.js"
      },
      "require": {
        "types": "./dist/patterns/*.d.cts",
        "default": "./dist/patterns/*.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests *.ts",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\" \"*.ts\" \"*.js\" \"*.json\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\" \"*.ts\" \"*.js\" \"*.json\"",
    "test:dist": "npm run build && node scripts/smoke-dist.mjs && node scripts/smoke-dist.cjs",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "changeset publish",
    "prepublishOnly": "npm test && npm run typecheck && npm run lint && npm run test:dist",
    "prepare": "lefthook install"
  },
  "author": "Enrique <enrique.azarquiel@gmail.com>",
  "license": "ISC",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.6.0",
    "lefthook": "^2.1.9",
    "prettier": "^3.9.4",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^7.3.6",
    "vitest": "^4.1.9"
  }
}
